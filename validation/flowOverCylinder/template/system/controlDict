FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         200;

deltaT          0.001;

writeControl    adjustableRunTime;

writeInterval   200;

writeFormat     binary;

writePrecision  6;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

adjustTimeStep  yes;

maxCo           0.5;

functions
{
    wake
    {
        type            lineSample;
        writeControl    writeTime;
        start           (4 -10 0);
        end             (4 10  0);
        N               100;
        fields          (p U);
    }
}

libs
(
    "code/libcode.so"
);

functions
{
    code
    {
        type    flowOverCylinder;
    }
}
