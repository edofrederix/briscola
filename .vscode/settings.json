{
    "files.trimTrailingWhitespace": true,
    "rewrap.wrappingColumn": 80,
    "files.associations": {
        "*.C": "cpp",
        "*.H": "cpp"
    },
    "editor.detectIndentation": false,
    "editor.tabSize": 4,
    "search.followSymlinks": false,
    "search.exclude": {
        "**/.git": true,
        "**/lnInclude": true,
        "**/*.dep": true,
    },
    "explorer.excludeGitIgnore": true
}
