-include $(GENERAL_RULES)/mplibType

EXE_INC = \
    $(PFLAGS) $(PINC) \
    -I./lnInclude \
    -I../briscolaCore/lnInclude \
    -I../briscolaMesh/lnInclude \
	-I../briscolaImmersedBoundary/lnInclude \
    -I$(LIB_SRC)/OpenFOAM/lnInclude \
    -I$(FFTW_HOME)/include \
    -I$(EIGEN_HOME)/include/eigen3 \
    $(if $(MKLROOT),-DMKL -m64 -I$(MKLROOT)/include,) \
    $(if $(SUITESPARSE_HOME),-DSUITESPARSE -I$(SUITESPARSE_HOME)/include/suitesparse,) \
    $(if $(SUPERLU_HOME),-DSUPERLU -I$(SUPERLU_HOME)/include,) \
    -Wno-old-style-cast \
    -Wno-unknown-pragmas

LIB_LIBS = \
    -L$(FOAM_USER_LIBBIN) \
    -L$(FFTW_HOME)/lib \
    $(if $(MKLROOT),-L${MKLROOT}/lib -lmkl_intel_lp64 -lmkl_sequential -lmkl_core,) \
    $(if $(SUITESPARSE_HOME),-L{SUITESPARSE_HOME}/lib64 -lumfpack,) \
    $(if $(SUPERLU_HOME),-L${SUPERLU_HOME}/lib -lsuperlu,) \
    -lbriscolaCore \
    -lbriscolaMesh \
    -lbriscolaImmersedBoundary \
    -lOpenFOAM \
    -lfftw3
