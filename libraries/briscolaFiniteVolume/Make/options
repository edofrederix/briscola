-include $(GENERAL_RULES)/mplibType

EXE_INC = \
    $(PFLAGS) $(PINC) \
    -I./lnInclude \
    -I../briscolaCore/lnInclude \
    -I../briscolaMesh/lnInclude \
	-I../briscolaImmersedBoundary/lnInclude \
    -I$(LIB_SRC)/OpenFOAM/lnInclude \
    -I$(FFTW_HOME)/include \
    -I$(EIGEN_HOME)/include/eigen3 \
    $(if $(SUPERLU_HOME),-DSUPERLU -I$(SUPERLU_HOME)/include,) \
    -Wno-old-style-cast \
    -Wno-unknown-pragmas

LIB_LIBS = \
    -L$(FOAM_USER_LIBBIN) \
    -L$(FFTW_HOME)/lib \
    $(if $(SUPERLU_HOME),-L${SUPERLU_HOME}/lib -lsuperlu,) \
    -lbriscolaCore \
    -lbriscolaMesh \
    -lbriscolaImmersedBoundary \
    -lOpenFOAM \
    -lfftw3
