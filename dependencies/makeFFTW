#!/bin/bash

PACKAGE=fftw
VERSION=3.3.10

# This is the installation location, can be modified:
PREFIX=$HOME/opt/$PACKAGE-$VERSION

# Build type (Release or Debug)
BUILD_TYPE=Release

case $1 in

    -clean)

        rm -fr build/$PACKAGE
        rm -fr $PREFIX

        echo "$PACKAGE removed"

        ;;

    -*|--*)

        echo "Unknown option $1"
        exit 1

        ;;

    *)

        if [ ! -d "build/$PACKAGE" ]; then

            if [ ! -f "$PACKAGE-$VERSION.tar.gz" ]; then

                echo "No file $PACKAGE-$VERSION.tar.gz found"
                exit

            fi

            mkdir -p build

            tar xzf $PACKAGE-$VERSION.tar.gz -C build || \
                { echo "Extraction of $PACKAGE failed"; exit; }

            mv build/$PACKAGE-$VERSION build/$PACKAGE

        fi

        mkdir -p build/$PACKAGE/build
        cd build/$PACKAGE/build

        cmake \
            -DDISABLE_FORTRAN=YES \
            -DCMAKE_INSTALL_PREFIX=$PREFIX \
            -DCMAKE_BUILD_TYPE=$BUILD_TYPE \
            .. || { echo "CMake command for $PACKAGE failed"; exit; }

        make -j ${WM_NCOMPPROCS:-4} || \
            { echo "Compilation of $PACKAGE failed"; exit; }

        make install || { echo "Installation of $PACKAGE failed"; exit; }

        echo "$PACKAGE built"

        echo ""
        echo "Add"
        echo ""
        echo "export FFTW_HOME=$PREFIX"
        echo "export LD_LIBRARY_PATH=\$FFTW_HOME/lib:\$LD_LIBRARY_PATH"
        echo ""
        echo "to your shell's rc file"

        ;;
esac
