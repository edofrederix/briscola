FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      f-colocated-vector;
}

boundaryConditions
{
    walls
    {
        type        Neumann;
        gradient    (0 0 0);
    }

    inlet
    {
        type        Dirichlet;
        value       (1 1 0);
    }

    outlet
    {
        type        Dirichlet;
        value       (0 0 0);
    }
}
