FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      f-colocated-vector;
}

boundaryConditions
{
    walls
    {
        type        Neumann;
        gradients   ((0 0 0));
    }

    inlet
    {
        type        Dirichlet;
        values      ((1 1 0));
    }

    outlet
    {
        type        Dirichlet;
        values      ((0 0 0));
    }
}
