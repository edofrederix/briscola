FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      briscolaSchemesDict;
}

laplacianSchemes
{
    laplacian(f.colocated)
    {
        type    linearGauss;
    }

    laplacian(f.staggered)
    {
        type    linearGauss;
    }
