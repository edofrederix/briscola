FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      briscolaSchemesDict;
}

ddtSchemes
{
    ddt(U)
    {
        type    Euler;
    }
}

laplacianSchemes
{
    laplacian(mu,U)
    {
        type    linearGauss;
    }
    laplacian(vf,p)
    {
        type    linearGauss;
    }
    laplacian(p)
    {
        type    linearGauss;
    }
}

divergenceSchemes
{
    div(phi,U)
    {
        type    midPointGauss;
    }
}

gradientSchemes
{
    grad(U)
    {
        type    midPointGauss;
    }
    grad(p)
    {
        type    midPointGauss;
    }
    grad(p.oldTime)
    {
        type    midPointGauss;
    }
    grad(q)
    {
        type    midPointGauss;
    }
}

faceGradientSchemes
{
    faceGrad(alpha)
    {
        type    linear;
    }
    faceGrad(p)
    {
        type    linear;
    }
    faceGrad(p.oldTime)
    {
        type    linear;
    }
    faceGrad(q)
    {
        type    linear;
    }
    faceGrad(rho)
    {
        type    linear;
    }
}

faceFluxSchemes
{
    flux(U)
    {
        type    linear;
    }
}

interpolationSchemes
{
    interp(alpha)
    {
        type    midPoint;
    }
    interp(sigma)
    {
        type    midPoint;
    }
    interp(v)
    {
        type    midPoint;
    }
}
