FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      U;
}

boundaryConditions
{
    inlet
    {
        type        periodic;
    }

    outlet
    {
        type        periodic;
    }

    sides
    {
        type        noSlip;
    }

    wall
    {
        type        MittalDirichlet;
        values      ((0 0 0));
    }
}
