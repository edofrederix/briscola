FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      briscolaSchemesDict;
}

laplacianSchemes
{
    default linearGauss;
}

divergenceSchemes
{
    default limitedGauss twoPhase upwind;
}

gradientSchemes
{
    default midPointGauss;
}

faceGradientSchemes
{
    default linear;
}

faceFluxSchemes
{
    default linear;
}

interpolationSchemes
{
    default midPoint;
}

rkScheme
{
    scheme Ascher222;
}
