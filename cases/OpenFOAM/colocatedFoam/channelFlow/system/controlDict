FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}

application     colocatedFoam;

startFrom       latestTime;

stopAt          endTime;

endTime         1;

deltaT          1e-5;

writeControl    adjustableRunTime;

writeInterval   0.1;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

adjustTimeStep  true;

maxCo           0.5;

libs
(
    "libfieldFunctionObjects.so"
);

functions
{
    div
    {
        type            div;
        field           phi;
        result          div;
        executeControl  writeTime;
        writeControl    writeTime;
    }
}
