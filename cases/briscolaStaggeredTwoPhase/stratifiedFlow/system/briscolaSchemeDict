FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      briscolaSchemesDict;
}

ddtSchemes
{
    ddt(U)
    {
        type    Euler;
    }
}

laplacianSchemes
{

    laplacian(vcf,p)
    {
        type    linearGauss;
    }
    laplacian(p)
    {
        type    linearGauss;
    }
    laplacian(mu,U)
    {
        type    linearGauss;
    }
}

divergenceSchemes
{
    div(phi,U)
    {
        type    midPointGauss;
    }
}

gradientSchemes
{
    grad(U)
    {
        type    midPointGauss;
    }
    stagGrad(p)
    {
        type    midPointGauss;
    }
    stagGrad(p.oldTime)
    {
        type    midPointGauss;
    }
    stagGrad(q)
    {
        type    midPointGauss;
    }

    // For CV
    grad(alpha)
    {
        type    midPointGauss;
    }
}

faceGradientSchemes
{
    faceGrad(p)
    {
        type    linear;
    }
    faceGrad(q)
    {
        type    linear;
    }
    faceGrad(alpha)
    {
        type    linear;
    }
    faceGrad(rho)
    {
        type    linear;
    }
}

faceFluxSchemes
{
    flux(U)
    {
        type    midPoint;
    }

    // For CV
    flux(grad(alpha))
    {
        type    midPoint;
    }
}

interpolationSchemes
{
    interp(alpha)
    {
        type    midPoint;
    }
    interp(sigma)
    {
        type    midPoint;
    }
}

reconstructionSchemes
{
    reconstruct(U)
    {
        type    midPoint;
    }
}
