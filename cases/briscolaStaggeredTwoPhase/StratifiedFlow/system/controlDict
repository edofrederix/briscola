FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         0.001;

deltaT          0.0001;

writeControl    adjustableRunTime;

writeInterval   0.0001;

writeFormat     binary;

writePrecision  6;

timeFormat      general;

timePrecision   6;

runTimeModifiable false;

adjustTimeStep  false;

maxCo           0.1;

libs
(
    "code/libcode.so"
);

functions
{
    init
    {
        type    initialCondition;
    }
}