FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      briscolaSchemesDict;
}

ddtSchemes
{
    ddt(U)
    {
        type    Euler;
    }
}

laplacianSchemes
{
    laplacian(v,p)
    {
        type    linearGauss;
    }

    laplacian(v,p)
    {
        type    linearGauss;
    }

    laplacian(p)
    {
        type    linearGauss;
    }

    laplacian(mu,U)
    {
        type    linearGauss;
    }
}

divergenceSchemes
{
    div(phi,U)
    {
        type    midPointGauss;
    }
}

gradientSchemes
{
    grad(p)
    {
        type    midPointGauss;
    }

    grad(q)
    {
        type    midPointGauss;
    }

    grad(alpha)
    {
        type    midPointGauss;
    }

    grad(U)
    {
        type    midPointGauss;
    }

    stagGrad(p)
    {
        type    midPointGauss;
    }

    stagGrad(p.oldTime)
    {
        type    midPointGauss;
    }

    stagGrad(alpha)
    {
        type    midPointGauss;
    }

    stagGrad(q)
    {
        type    midPointGauss;
    }
}

faceGradientSchemes
{
    faceGrad(p)
    {
        type    linear;
    }

    faceGrad(q)
    {
        type    linear;
    }
}

faceFluxSchemes
{
    flux(U)
    {
        type    midPoint;
    }

    flux(grad(alpha))
    {
        type    midPoint;
    }
}

interpolationSchemes
{
    interp(alpha)
    {
        type    midPoint;
    }

    interp(rho)
    {
        type    midPoint;
    }

    interp(v)
    {
        type    midPoint;
    }

    interp(kappa)
    {
        type    curvature;
    }

    interp(checkCurv)
    {
        type    curvature;
    }

    interp(min(rho1,rho2))
    {
        type    midPoint;
    }
}

reconstructionSchemes
{
    reconstruct(U)
    {
        type    midPoint;
    }
}
