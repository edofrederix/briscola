FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      U;
}

boundaryConditions
{
    walls
    {
        type        noSlip;
    }

    inlet
    {
        type        Dirichlet;
        values      (1 0 0);
    }

    outlet
    {
        type        outflow;
    }

    empties
    {
        type        empty;
    }
}
