FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      briscolaSchemesDict;
}

ddtSchemes
{
    ddt(U)
    {
        type    Euler;
    }
}

laplacianSchemes
{
    laplacian(p)
    {
        type    linearGauss;
    }

    laplacian(const,U)
    {
        type    linearGauss;
    }
}

divergenceSchemes
{
    div(phi,U)
    {
        type    midPointGauss;
    }
}

gradientSchemes
{
    stagGrad(p)
    {
        type    midPointGauss;
    }
}

faceGradientSchemes
{
    faceGrad(p)
    {
        type    linear;
    }
}

faceFluxSchemes
{
    flux(U)
    {
        type    midPoint;
    }
}
