FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         200;

deltaT          1e-4;

writeControl    adjustableRunTime;

writeInterval   10;

writeFormat     binary;

writePrecision  6;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

adjustTimeStep  true;

maxCo           0.4;

functions
{
    timeAverage
    {
        type        timeAverage;
        fields      (U Uc);
        startTime   100;
    }

    force
    {
        type        stagImmersedBoundaryForce;
        ibName      cylinder;
        log         true;
    }
}

