FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      alpha;
}

boundaryConditions
{
    inlet
    {
        type        periodic;
    }

    outlet
    {
        type        periodic;
    }

    sides
    {
        type        Neumann;
        gradient    0;
    }

    wall
    {
        type        empty;
    }
}
