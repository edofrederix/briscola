FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      briscolaSchemesDict;
}

laplacianSchemes
{
    default linearGauss;
}

divergenceSchemes
{
    div(phi,U) limitedGauss twoPhase vanLeer;
}

gradientSchemes
{
    default midPointGauss;
}

faceGradientSchemes
{
    default linear;
}

faceDotGradientSchemes
{
    default linear;
}

faceFluxSchemes
{
    default linear;
}

interpolationSchemes
{
    default midPoint;
}

rkScheme
{
    scheme  CNABM;
}
