FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      U;
}

boundaryConditions
{
    inlet
    {
        type        Dirichlet;
        value       (1 0 0);
    }

    outlet
    {
        type        outflow;
    }

    wall
    {
        type        noSlip;
    }

    top
    {
        type        slip;
    }

    bottom
    {
        type        slip;
    }

    empties
    {
        type        empty;
    }
}
