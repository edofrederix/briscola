FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      U;
}

boundaryConditions
{
    walls
    {
        type        noSlip;
    }

    inlet_mapped
    {
        type        mapped;
        setAverage  true;
        average     (1 0 0);
    }

    inlet
    {
        type        periodic;
    }

    outlet_mapped
    {
        type        Neumann;
        gradient    (0 0 0);
    }

    outlet
    {
        type        periodic;
    }

    ib
    {
        type        MittalDirichlet;
        value       (0 0 0);
    }
}
