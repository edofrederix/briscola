FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      U;
}

boundaryConditions
{
    walls
    {
        type        noSlip;
    }

    inlet_mapped
    {
        type        mapped;
        setAverages (true);
        averages    ((1 0 0));
    }

    inlet
    {
        type        periodic;
    }

    outlet_mapped
    {
        type        Neumann;
        gradients   ((0 0 0));
    }

    outlet
    {
        type        periodic;
    }

    ib
    {
        type        MittalDirichlet;
        values      ((0 0 0));
    }
}
