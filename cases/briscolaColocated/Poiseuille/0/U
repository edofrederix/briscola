FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      U;
}

boundaryConditions
{
    walls
    {
        type        Dirichlet;
        values      ((0 0 0));
    }

    inlet
    {
        type        Dirichlet;
        values      ((1 0 0));
    }

    outlet
    {
        type        Neumann;
        gradients   ((0 0 0));
    }

    empties
    {
        type        empty;
    }
}
